<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group13.movieproductionhouse.akkhorik.controller.ExecutiveController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <Label text="Studio Executive Portal" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TabPane>
        <Tab text="Project Review" closable="false">
            <VBox spacing="10.0">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10" />
                </padding>
                <HBox spacing="10.0">
                    <Button text="1. Review Pitches" onAction="#reviewPitches" />
                    <Button text="2. Approve Budget" onAction="#approveBudget" />
                    <Button text="3. Monitor Production" onAction="#monitorProduction" />
                    <Button text="4. Market Trends" onAction="#analyzeTrends" />
                </HBox>
                <TableView fx:id="pitchesTable" prefHeight="200.0">
                    <columns>
                        <TableColumn text="ID" prefWidth="60" />
                        <TableColumn text="Title" prefWidth="150" />
                        <TableColumn text="Producer" prefWidth="100" />
                        <TableColumn text="Budget Est." prefWidth="80" />
                        <TableColumn text="Status" prefWidth="80" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="Production &amp; Finance" closable="false">
            <VBox spacing="10.0">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10" />
                </padding>
                <HBox spacing="10.0">
                    <Button text="5. Approve Talent Deals" onAction="#approveTalentDeals" />
                    <Button text="6. Manage Milestones" onAction="#manageMilestones" />
                    <Button text="7. Test Screening" onAction="#reviewTestScreening" />
                    <Button text="8. Evaluate ROI" onAction="#evaluateROI" />
                </HBox>
                <TableView fx:id="budgetsTable" prefHeight="200.0">
                    <columns>
                        <TableColumn text="Project ID" prefWidth="80" />
                        <TableColumn text="Total Budget" prefWidth="100" />
                        <TableColumn text="Spent" prefWidth="100" />
                        <TableColumn text="Remaining" prefWidth="100" />
                        <TableColumn text="Status" prefWidth="80" />
                    </columns>
                </TableView>
                <TextArea fx:id="outputArea" editable="false" prefHeight="100.0" promptText="Operation output will appear here..." />
            </VBox>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Refresh Data" onAction="#refreshData" />
        <Button text="Back to Main Menu" onAction="#backToMain" />
    </HBox>
</VBox>