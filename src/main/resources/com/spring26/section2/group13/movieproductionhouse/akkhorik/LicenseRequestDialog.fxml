<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <GridPane hgap="10.0" vgap="10.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label text="Film:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="filmTitleField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Exhibitor Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="exhibitorField" promptText="e.g., AMC Theatres" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Region:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="regionField" promptText="e.g., North America" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Number of Screens:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="screensField" promptText="e.g., 200" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Revenue Share %:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="shareField" promptText="e.g., 55" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label text="Start Date:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <DatePicker fx:id="startDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <Label text="End Date:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <DatePicker fx:id="endDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="6" />
        </GridPane>
    </content>
    <ButtonType>
        <ButtonType text="Submit" buttonData="OK_DONE" />
        <ButtonType text="Cancel" buttonData="CANCEL_CLOSE" />
    </ButtonType>
</DialogPane>