<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group13.movieproductionhouse.akkhorik.controller.ExhibitorController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <Label text="Exhibitor Portal" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TabPane>
        <Tab text="Films &amp; Licensing" closable="false">
            <VBox spacing="10.0">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10" />
                </padding>
                <HBox spacing="10.0">
                    <Button text="1. Browse Available Films" onAction="#browseFilms" />
                    <Button text="2. Request License" onAction="#requestLicense" />
                    <Button text="3. Download DCP" onAction="#downloadDCP" />
                </HBox>
                <TableView fx:id="filmsTable" prefHeight="200.0">
                    <columns>
                        <TableColumn text="ID" prefWidth="60" />
                        <TableColumn text="Title" prefWidth="150" />
                        <TableColumn text="Genre" prefWidth="80" />
                        <TableColumn text="Rating" prefWidth="50" />
                        <TableColumn text="Status" prefWidth="80" />
                        <TableColumn text="License Fee" prefWidth="80" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="Screenings &amp; Operations" closable="false">
            <VBox spacing="10.0">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10" />
                </padding>
                <HBox spacing="10.0">
                    <Button text="4. Schedule Screenings" onAction="#scheduleScreenings" />
                    <Button text="5. Track Box Office" onAction="#trackBoxOffice" />
                    <Button text="6. Manage KDM" onAction="#manageKDM" />
                    <Button text="7. End Engagement" onAction="#endEngagement" />
                    <Button text="8. Settlement Report" onAction="#generateSettlement" />
                </HBox>
                <TableView fx:id="screeningsTable" prefHeight="200.0">
                    <columns>
                        <TableColumn text="ID" prefWidth="60" />
                        <TableColumn text="Film ID" prefWidth="80" />
                        <TableColumn text="Showtime" prefWidth="140" />
                        <TableColumn text="Screen" prefWidth="60" />
                        <TableColumn text="Tickets Sold" prefWidth="80" />
                        <TableColumn text="Revenue" prefWidth="80" />
                    </columns>
                </TableView>
                <TextArea fx:id="outputArea" editable="false" prefHeight="100.0" promptText="Operation output will appear here..." />
            </VBox>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Refresh Data" onAction="#refreshData" />
        <Button text="Back to Main Menu" onAction="#backToMain" />
    </HBox>
</VBox>