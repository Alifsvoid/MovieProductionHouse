<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <GridPane hgap="10.0" vgap="10.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label text="Film:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="filmField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Screen Number:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="screenField" promptText="e.g., 5" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Capacity:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="capacityField" promptText="e.g., 250" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Ticket Price ($):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="priceField" promptText="e.g., 12.50" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Date (YYYY-MM-DD):" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="dateField" promptText="2025-12-01" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label text="Time (HH:MM):" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <TextField fx:id="timeField" promptText="19:00" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        </GridPane>
    </content>
    <ButtonType>
        <ButtonType text="Schedule" buttonData="OK_DONE" />
        <ButtonType text="Cancel" buttonData="CANCEL_CLOSE" />
    </ButtonType>
</DialogPane>