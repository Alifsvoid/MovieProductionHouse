<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label fx:id="projectLabel" style="-fx-font-weight: bold;" />
            <TableView fx:id="lineItemsTable" prefHeight="200.0">
                <columns>
                    <TableColumn text="Category" prefWidth="150" />
                    <TableColumn text="Requested ($)" prefWidth="100" />
                    <TableColumn text="Approved ($)" prefWidth="100" />
                </columns>
            </TableView>
            <HBox spacing="10.0">
                <Label text="Total Requested:" />
                <Label fx:id="totalRequestedLabel" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Total Approved:" />
                <Label fx:id="totalApprovedLabel" />
            </HBox>
            <Separator />
            <HBox spacing="10.0">
                <Button text="Approve Budget" onAction="#approveBudget" />
                <Button text="Request Revision" onAction="#requestRevision" />
                <Button text="Cancel" onAction="#closeDialog" />
            </HBox>
        </VBox>
    </content>
</DialogPane>