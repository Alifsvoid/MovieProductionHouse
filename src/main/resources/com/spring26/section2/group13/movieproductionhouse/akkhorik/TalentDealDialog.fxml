<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label fx:id="talentNameLabel" style="-fx-font-weight: bold;" />
            <Label fx:id="roleLabel" />
            <Label fx:id="projectLabel" />
            <Separator />
            <GridPane hgap="10.0" vgap="5.0">
                <Label text="Base Salary ($):" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label fx:id="salaryLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Backend Points (%):" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label fx:id="pointsLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Estimated Break-Even Impact:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label fx:id="impactLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </GridPane>
            <Separator />
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button text="Approve Deal" onAction="#approveDeal" />
                <Button text="Reject" onAction="#rejectDeal" />
                <Button text="Counter Offer" onAction="#counterOffer" />
                <Button text="Cancel" onAction="#closeDialog" />
            </HBox>
        </VBox>
    </content>
</DialogPane>