<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group13.movieproductionhouse.Fuad.FinanceApprovePurchasesController">
    <children>
        <Label layoutX="32.0" layoutY="25.0" prefHeight="66.0" prefWidth="398.0" text="Pending Purchase Approvals">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <TableView fx:id="purchaseTable" layoutX="32.0" layoutY="100.0" prefHeight="200.0" prefWidth="536.0">
            <columns>
                <TableColumn fx:id="requestcol" prefWidth="120.0" text="Request ID" />
                <TableColumn fx:id="itemnamecol" prefWidth="150.0" text="Item Name" />
                <TableColumn fx:id="amountcol" prefWidth="110.0" text="Amount" />
                <TableColumn fx:id="departmentcol" prefWidth="155.0" text="Department" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox layoutX="368.0" layoutY="320.0" spacing="15.0">
            <children>
                <Button fx:id="rejectBtn" mnemonicParsing="false" onAction="#handleRejectPurchase" prefWidth="80.0" text="Reject" />
                <Button fx:id="approveBtn" mnemonicParsing="false" onAction="#handleApprovePurchase" prefWidth="100.0" text="Approve" />
            </children>
        </HBox>
    </children>
</AnchorPane>
