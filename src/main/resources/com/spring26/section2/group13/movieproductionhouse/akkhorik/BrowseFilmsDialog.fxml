<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label text="Available Films" style="-fx-font-weight: bold;" />
            <TableView fx:id="filmsTable" prefHeight="300.0" prefWidth="500.0">
                <columns>
                    <TableColumn text="ID" prefWidth="60" />
                    <TableColumn text="Title" prefWidth="150" />
                    <TableColumn text="Genre" prefWidth="80" />
                    <TableColumn text="Rating" prefWidth="50" />
                    <TableColumn text="Duration" prefWidth="60" />
                    <TableColumn text="License Fee" prefWidth="80" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button text="Select" onAction="#selectFilm" />
                <Button text="Cancel" onAction="#closeDialog" />
            </HBox>
        </VBox>
    </content>
</DialogPane>