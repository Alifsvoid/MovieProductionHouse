<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label fx:id="titleLabel" style="-fx-font-weight: bold;" />
            <Label fx:id="producerLabel" />
            <TextArea fx:id="synopsisArea" editable="false" prefHeight="100.0" wrapText="true" />
            <Label text="Rating (1-10):" />
            <Spinner fx:id="ratingSpinner" min="1" max="10" initialValue="5" editable="true" />
            <Label text="Comments:" />
            <TextArea fx:id="commentsArea" promptText="Enter review comments..." prefHeight="80.0" wrapText="true" />
        </VBox>
    </content>
    <ButtonType>
        <ButtonType text="Submit Review" buttonData="OK_DONE" />
        <ButtonType text="Cancel" buttonData="CANCEL_CLOSE" />
    </ButtonType>
</DialogPane>