<AnchorPane prefHeight="532.0" prefWidth="621.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group13.movieproductionhouse.Fuad.FinanceCreateBudgetController">
   <children>
