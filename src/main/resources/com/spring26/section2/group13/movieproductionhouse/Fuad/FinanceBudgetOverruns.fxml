<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group13.movieproductionhouse.Fuad.FinanceOverrunController">
    <children>
        <Label layoutX="126.0" layoutY="50.0" prefHeight="46.0" prefWidth="398.0" text="Budget Overrun Alerts">
            <font>
                <Font name="System Bold" size="30.0" />
            </font>
        </Label>

        <TableView fx:id="overrunTable" layoutX="50.0" layoutY="125.0" prefHeight="200.0" prefWidth="550.0">
            <columns>
                <TableColumn fx:id="deptCol" prefWidth="137.0" text="Department" />
                <TableColumn fx:id="allocatedCol" prefWidth="137.0" text="Allocated ($)" />
                <TableColumn fx:id="actualCol" prefWidth="137.0" text="Actual Spent ($)" />
                <TableColumn fx:id="varianceCol" prefWidth="137.0" text="Variance ($)" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Label fx:id="totalOverageLabel" layoutX="400.0" layoutY="340.0" text="Total Overage: $0.00">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <Button fx:id="applyBtn" layoutX="400.0" layoutY="370.0" mnemonicParsing="false" onAction="#handleApplyAction" prefHeight="35.0" prefWidth="120.0" text="Apply Action" />
    </children>
</AnchorPane>